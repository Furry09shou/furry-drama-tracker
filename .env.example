# =============================================================================
# 兽剧聚合平台 - 环境变量示例
# 复制本文件为 .env 并填入真实值。切勿将 .env 提交到版本库。
# =============================================================================

# ---- 运行环境 ----
# development | production
NODE_ENV=development
# 后端监听端口
PORT=5000

# ---- 数据库 ----
# MongoDB 连接字符串
MONGO_URI=mongodb://127.0.0.1:27017/furry_drama_tracker

# ---- 密钥 ----
# JWT 签名密钥（生产环境必须至少 32 字符，建议 64 字符随机串）
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
# 字段加密密钥（用于站点内容敏感字段加密，建议与 JWT_SECRET 不同）
# 未设置时回退到 JWT_SECRET 以兼容旧数据
ENCRYPTION_KEY=change-me-to-another-long-random-secret
# ALTCHA 验证码 HMAC 密钥（未设置时由 JWT_SECRET 派生）
ALTCHA_HMAC_KEY=

# ---- 超级管理员初始化 ----
# seedAdmin.js 脚本使用，仅首次运行生效
SUPERADMIN_EMAIL=admin@furry09.com
SUPERADMIN_ACCOUNT_ID=admin
# 不设置则自动生成 20 位随机密码并打印到控制台
SUPERADMIN_PASSWORD=

# ---- 前端地址 / 站点地址 ----
# 用于邮件验证链接等
FRONTEND_URL=http://localhost:3000
# 用于 RSS 等
SITE_URL=http://localhost:3000
# 额外允许的 CORS 源（逗号分隔）
ALLOWED_ORIGINS=

# ---- 邮件服务 ----
EMAIL_HOST=smtp.example.com
EMAIL_PORT=465
EMAIL_USER=your-email@example.com
EMAIL_PASS=your-email-password
EMAIL_FROM_NAME=兽剧聚合平台

# ---- Web Push (VAPID) ----
# 不设置则禁用推送通知
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@furry09.com

# ---- 测试环境 ----
# 测试环境下跳过新设备登录验证的邮箱列表（逗号分隔），仅用于测试，生产环境留空
DEMO_EMAILS=demo@furry09.com
# 开发/测试 API 口令 — 通过 X-Dev-Token 请求头传入即可绕过 altcha 验证码、邮箱验证、设备验证
# 仅用于自动化测试，生产环境请留空
DEV_API_TOKEN=
